{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "phone",
  "title": "Phone",
  "description": "Call anyone in your Contacts through your iPhone in two keystrokes via macOS Continuity.",
  "icon": "extension-icon.png",
  "author": "amir01",
  "categories": [
    "Communication",
    "Productivity"
  ],
  "keywords": [
    "phone",
    "call",
    "dial",
    "dialer",
    "contacts",
    "contact",
    "facetime",
    "continuity",
    "iphone",
    "speeddial",
    "click-to-call",
    "ring"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "call",
      "title": "Call",
      "subtitle": "Continuity",
      "description": "Search your contacts and call them through your iPhone with one keystroke.",
      "mode": "view",
      "keywords": [
        "phone",
        "dial",
        "facetime",
        "contact",
        "continuity",
        "iphone",
        "ring",
        "speeddial"
      ],
      "arguments": [
        {
          "name": "name",
          "placeholder": "Name",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "name": "refresh-contacts",
      "title": "Refresh Contacts",
      "subtitle": "Continuity",
      "description": "Rebuild the cached contacts list from macOS Contacts.",
      "mode": "no-view",
      "keywords": [
        "contacts",
        "refresh",
        "sync",
        "reload"
      ]
    }
  ],
  "preferences": [
    {
      "name": "defaultAction",
      "title": "Default Action",
      "description": "What happens when you press Enter on a contact.",
      "type": "dropdown",
      "default": "tel",
      "required": false,
      "data": [
        { "title": "Call (Phone)", "value": "tel" },
        { "title": "FaceTime Audio", "value": "facetime-audio" },
        { "title": "FaceTime Video", "value": "facetime" }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.16",
    "@raycast/utils": "^2.2.4",
    "libphonenumber-js": "^1.13.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "eslint": "^9.0.0",
    "prettier": "^3.8.3",
    "typescript": "^5.6.0"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
